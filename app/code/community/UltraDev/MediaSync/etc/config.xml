<?xml version="1.0"?>
<config>
    <modules>
        <UltraDev_MediaSync>
            <version>1.1.0</version>
        </UltraDev_MediaSync>
    </modules>
    <global>
        <models>
            <ultradev_mediasync>
                <class>UltraDev_MediaSync_Model</class>
            </ultradev_mediasync>
        </models>
        <helpers>
            <ultradev_mediasync>
                <class>UltraDev_MediaSync_Helper</class>
            </ultradev_mediasync>
        </helpers>
        <events>
            <catalog_product_save_after>
                <observers>
                    <ultradev_mediasync>
                        <class>ultradev_mediasync/observer</class>
                        <method>syncProductMedia</method>
                    </ultradev_mediasync>
                </observers>
            </catalog_product_save_after>
            <catalog_category_save_after>
                <observers>
                    <ultradev_mediasync>
                        <class>ultradev_mediasync/observer</class>
                        <method>syncCategoryMedia</method>
                    </ultradev_mediasync>
                </observers>
            </catalog_category_save_after>
            <cms_block_save_after>
                <observers>
                    <ultradev_mediasync>
                        <class>ultradev_mediasync/observer</class>
                        <method>syncCmsMedia</method>
                    </ultradev_mediasync>
                </observers>
            </cms_block_save_after>
            <cms_page_save_after>
                <observers>
                    <ultradev_mediasync>
                        <class>ultradev_mediasync/observer</class>
                        <method>syncCmsMedia</method>
                    </ultradev_mediasync>
                </observers>
            </cms_page_save_after>
            <adminhtml_cache_flush_all>
                <observers>
                    <ultradev_mediasync_flush>
                        <class>ultradev_mediasync/observer</class>
                        <method>flushFbminifyFromR2</method>
                    </ultradev_mediasync_flush>
                </observers>
            </adminhtml_cache_flush_all>
            <adminhtml_cache_flush_system>
                <observers>
                    <ultradev_mediasync_flush_system>
                        <class>ultradev_mediasync/observer</class>
                        <method>flushFbminifyFromR2</method>
                    </ultradev_mediasync_flush_system>
                </observers>
            </adminhtml_cache_flush_system>
        </events>
    </global>
    <frontend>
        <events>
            <http_response_send_before>
                <observers>
                    <ultradev_mediasync_fbminify>
                        <class>ultradev_mediasync/observer</class>
                        <method>syncFbminify</method>
                    </ultradev_mediasync_fbminify>
                </observers>
            </http_response_send_before>
        </events>
    </frontend>
    <adminhtml>
        <acl>
            <resources>
                <admin>
                    <children>
                        <system>
                            <children>
                                <config>
                                    <children>
                                        <ultradev_mediasync translate="title">
                                            <title>UltraDev Media Sync</title>
                                        </ultradev_mediasync>
                                    </children>
                                </config>
                            </children>
                        </system>
                    </children>
                </admin>
            </resources>
        </acl>
    </adminhtml>
    <default>
        <ultradev_mediasync>
            <general>
                <enabled>0</enabled>
                <bucket></bucket>
                <endpoint></endpoint>
                <access_key></access_key>
                <secret_key></secret_key>
            </general>
            <fbminify>
                <enabled>0</enabled>
            </fbminify>
        </ultradev_mediasync>
    </default>
</config>
