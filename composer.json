{
  "name": "ultradev/openmage-mediasync-cloudflare-r2",
  "description": "Sync Magento/OpenMage media files with Cloudflare R2 and serve via CDN",
  "type": "magento-module",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "aws/aws-sdk-php": "^3.0",
    "magento-hackathon/magento-composer-installer": "^3.0"
  },
  "extra": {
    "magento-root-dir": "../../..",
    "map": [
      ["app/code/community/UltraDev/MediaSync", "app/code/community/UltraDev/MediaSync"],
      ["app/etc/modules/UltraDev_MediaSync.xml", "app/etc/modules/UltraDev_MediaSync.xml"],
      ["shell/ultradev_media_sync.php", "shell/ultradev_media_sync.php"]
    ]
  }
}
